      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"folders\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"parent_id\" TEXT NULL REFERENCES folders (id) ON DELETE SET NULL, \"sort_order\" INTEGER NOT NULL DEFAULT 0, \"collapsed\" INTEGER NOT NULL DEFAULT 0 CHECK (\"collapsed\" IN (0, 1)), \"created_at\" INTEGER NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
