<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network: SSH/SFTP connections -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service: keeps SSH connections alive when screen is locked -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Storage: local file browser for SFTP transfers -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Camera: QR scanner (used only for the "Scan QR" action in Settings) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="LFssh"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:requestLegacyExternalStorage="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"
            />

            <!-- Main launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: letsflutssh://connect?host=X&port=22&user=Y -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="letsflutssh" />
            </intent-filter>

            <!-- Open SSH key files (.pem, .key, .pub) and .lfs export archives -->
            <!-- Note: mimeType="*/*" would match ALL files (Android ORs data attributes).
                 Use application/octet-stream — most file managers send this for unknown extensions. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="application/octet-stream" />
                <data android:pathPattern=".*\\.pem" />
                <data android:pathPattern=".*\\.key" />
                <data android:pathPattern=".*\\.pub" />
                <data android:pathPattern=".*\\.lfs" />
            </intent-filter>
            <!-- Some file managers send PEM-specific MIME types -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="application/x-pem-file" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="application/x-x509-ca-cert" />
            </intent-filter>
        </activity>

        <!-- QR scanner activity: shown only when the user taps "Scan QR".
             Launched as a singleTask child of MainActivity through a
             MethodChannel; result is delivered back via Activity.onActivityResult. -->
        <activity
            android:name=".QrScannerActivity"
            android:exported="false"
            android:theme="@style/QrScannerTheme"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|layoutDirection|fontScale|density" />

        <!-- Flutter engine registration -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Foreground service: keeps SSH alive when screen is locked -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />
    </application>

    <!-- Package visibility for text processing -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

</manifest>